{
  "version": 2,
  "name": "dcp-gestao-producao",
  "rewrites": [
    { "source": "/", "destination": "/PCP-gestao-producao.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
